# Cognitive Core — Environment Variables
# Source this before running anything: source .env

# AMD RX 7900 XTX (gfx1100) with ROCm 7.2
export HSA_OVERRIDE_GFX_VERSION=11.0.0

# Hide the AMD Radeon iGPU — without this, model allocation
# crashes with "Memory access fault by GPU node-2"
export ROCR_VISIBLE_DEVICES=0

# Skip aiter C++ JIT build (not needed for FP16 inference,
# and the JIT build fails on ROCm 7.2.4 due to hipcc flag mismatch)
export AITER_TRITON_ONLY=1
